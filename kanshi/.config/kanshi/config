# Kanshi - automatic display profile switching for Sway
# Edit profiles to match your monitors. Run 'kanshi -d' to detect connected outputs.

# Default: any monitor configuration (fallback)
profile {
    output eDP-1 position 0,0 mode 1920x1080@60Hz
}

# Example: external monitor only (uncomment and adjust for your setup)
# profile {
#     output "DP-1" position 0,0 mode 2560x1440@60Hz
# }

# Example: laptop + external monitor (uncomment and adjust)
# profile {
#     output eDP-1 position 0,900 mode 1920x1080@60Hz
#     output "DP-1" position 1920,0 mode 2560x1440@60Hz
# }
