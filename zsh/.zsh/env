export CLICOLOR=1
export EDITOR=nvim
export VISUAL=nvim
export KEYTIMEOUT=1
export TERMINAL=foot

# Qt theme integration (uses GTK theme via qt5ct/qt6ct)
export QT_QPA_PLATFORMTHEME=qt5ct

export GOPATH=$HOME/go
export GO111MODULE=on

# Consolidated PATH exports
export PATH=$PATH:$HOME/.npm-global/bin:$HOME/bin:$HOME/.local/bin:/usr/local/go/bin:$HOME/go/bin

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# Flatpak app directories (so wofi drun can find them)
export XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}:${HOME}/.local/share/flatpak/exports/share:/var/lib/flatpak/exports/share"

# opencode
export PATH=/home/oberg/.opencode/bin:$PATH

# GNOME Keyring (gcr) as SSH agent
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/gcr/ssh"
