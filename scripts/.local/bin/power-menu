#!/usr/bin/env bash
# Power menu ŌĆö wofi dmenu with lock, logout, reboot, shutdown, suspend.
# Called by the Waybar custom/power module or the $mod+Shift+x keybinding.
set -euo pipefail

choices="¾░īŠ Lock\n¾░ŚĮ Logout\n’ĆĪ Reboot\n’Ćæ Shutdown\n’åå Suspend"

choice=$(echo -e "$choices" | wofi --show dmenu --dmenu -p "Power: ")

case "$choice" in
  "¾░īŠ Lock")       swaylock ;;
  "¾░ŚĮ Logout")     swaymsg exit ;;
  "’ĆĪ Reboot")     systemctl reboot ;;
  "’Ćæ Shutdown")   systemctl poweroff ;;
  "’åå Suspend")    systemctl suspend ;;
esac
